# TEST PUSHOVER CON SEZIONE L100-N-mm
# CODE_ASTER V12

DEBUT();

mail=LIRE_MAILLAGE(FORMAT='MED',);

L100=LIRE_MAILLAGE(UNITE=21,
                      FORMAT='ASTER',);

L100=DEFI_GROUP(reuse =L100,
                   MAILLAGE=L100,
                   CREA_GROUP_MA=_F(NOM='TSEZ',
                                    TOUT='OUI',),
                   CREA_GROUP_NO=(_F(TOUT_GROUP_MA='OUI',),
                                  _F(GROUP_MA='L100_P1',
                                     NOM='L100P1',),),);

C_L100=MACR_CARA_POUTRE(MAILLAGE=L100,
                        TABLE_CARA='OUI',
                        GROUP_MA_BORD='L100_BE',
                        NOM='L100',
                        GROUP_NO='L100P1',);

modele=AFFE_MODELE(MAILLAGE=mail,
                   AFFE=_F(TOUT='OUI',
                           PHENOMENE='MECANIQUE',
                           MODELISATION='POU_D_TGM',),);

#MODELLO IN N mm

Sigmaeps=DEFI_FONCTION(
                       NOM_PARA='EPSI',
                       VALE=(0.0016 ,330.0 ,
                             0.0032 ,350.0 ,
                             0.0064 ,367.0 ,
                             0.0128 ,387.0 ,
                             0.02 ,401.0 ,
                             0.027 ,410.0 ,
                             0.04 ,420.0 ,
                             0.07 ,437.0 ,
                             0.1 ,450.0 ,
                             0.15 ,473.0 ,
                             0.2 ,490.0 ,
                             0.3 ,510.0 ,),
                       INTERPOL='LIN',
                       PROL_DROITE='LINEAIRE',
                       PROL_GAUCHE='EXCLU',);

#Courbe acier en traction 

acier=DEFI_MATERIAU(ELAS=_F(E=206000.0,
                            NU=0.27,
                            RHO=7.85e-06,),
                    TRACTION=_F(SIGM=Sigmaeps,),);

F_L100=DEFI_GEOM_FIBRE(SECTION=_F(GROUP_FIBRE='G_L100',
                                 GROUP_MA_SECT='L100_S1',
                                 MAILLAGE_SECT=L100,
                                 COOR_AXE_POUTRE=(0.0,0.0),),);

CL100=DEFI_COMPOR(GEOM_FIBRE=F_L100,
                   MATER_SECT=acier,
                   MULTIFIBRE=_F(GROUP_FIBRE='G_L100',
                                 MATER=acier,
                                 RELATION='VMIS_ISOT_TRAC',),);

M_L100=AFFE_MATERIAU(MAILLAGE=mail,
                      AFFE=_F(GROUP_MA='GROUPM',
                              MATER=acier,),
                      AFFE_COMPOR=_F(GROUP_MA='GROUPM',
                                     COMPOR=CL100,),);

carap=AFFE_CARA_ELEM(MODELE=modele,
                     POUTRE=_F(SECTION='GENERALE',
                               GROUP_MA='GROUPM',
                               TABLE_CARA=C_L100,
                               NOM_SEC='L100',),
                     ORIENTATION=_F(GROUP_MA='GROUPM',
                                    CARA='VECT_Y',
                                    VALE=(1.0,0.0,0.0,),),
                     GEOM_FIBRE=F_L100,
                      MULTIFIBRE=_F(GROUP_MA=('GROUPM', ),
                                       GROUP_FIBRE=('G_L100', ),
                                       PREC_AIRE=1.E-2,
                                       PREC_INERTIE=2,),);

Vincules=AFFE_CHAR_MECA(MODELE=modele,
                        DDL_IMPO=_F(GROUP_NO='I1',
                                    DX=0.0,
                                    DY=0.0,
                                    DZ=0.0,
                                    DRX=0.0,
                                    DRY=0.0,
                                    DRZ=0.0,),);
t0 = 0.0;

t1 = 1;

tsteps = 100;


charg=AFFE_CHAR_MECA(MODELE=modele,
                     FORCE_NODALE=_F(GROUP_NO='F1',
                                     FY=5000.0,),);

ramp=DEFI_FONCTION(
                   NOM_PARA='INST',
                   VALE=(t0 ,0.0 ,
                         t1 ,1.0 ,),
                   INFO=2,
                   TITRE='ramp',);

time=DEFI_LIST_REEL(DEBUT=0.0,
                    INTERVALLE=_F(JUSQU_A=t1,
                                  NOMBRE=tsteps,),
                    INFO=2,
                    TITRE='time',);

deflist=DEFI_LIST_INST(DEFI_LIST=_F(METHODE='AUTO',
                                    LIST_INST=time,
                                    PAS_MINI=0.0005,),);

Resultat=STAT_NON_LINE(MODELE=modele,
                       CHAM_MATER=M_L100,
                       CARA_ELEM=carap,
                       EXCIT=(_F(CHARGE=Vincules,),
                              _F(CHARGE=charg,
                                 FONC_MULT=ramp,),),
                       COMPORTEMENT=_F(TOUT='OUI',
                                       RELATION='MULTIFIBRE',
                                       DEFORMATION='PETIT',),
                       INCREMENT=_F(LIST_INST=deflist,),
                       NEWTON=_F(PREDICTION='ELASTIQUE',
                                 REAC_ITER=1,),
                       CONVERGENCE=_F(ITER_GLOB_MAXI=20,),
                       ARCHIVAGE=_F(PAS_ARCH=2,),);

Resultat=CALC_CHAMP(reuse =Resultat,
                    MODELE=modele,
                    RESULTAT=Resultat,
                    TOUT='OUI',
                    CONTRAINTE=('EFGE_ELNO','EFGE_NOEU',),);

IMPR_RESU(FORMAT='MED',
	CONCEPT=_F(CARA_ELEM=carap,
                     REPERE_LOCAL='OUI',
                     MODELE=modele,),
          RESU=_F(RESULTAT=Resultat,
                  NOM_CHAM=('DEPL','EFGE_NOEU',),
                  TOUT_CMP='OUI',),);
FIN();
